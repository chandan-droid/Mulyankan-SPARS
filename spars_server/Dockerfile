# Stage 1: Build using Gradle wrapper from the project
FROM eclipse-temurin:17-jdk AS builder

WORKDIR /app
COPY . .

# Build Spring Boot jar (skip tests for faster image build)
RUN gradle build -x test

# Stage 2: Run the app
FROM eclipse-temurin:17-jre

WORKDIR /app

# Copy boot jar generated by Gradle
COPY --from=builder /app/build/libs/*.jar app.jar

EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
